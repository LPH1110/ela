datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum EmployeeStatus { 
  ONBOARDING
  ACTIVE
  OFFBOARDED 
}

enum JobStatus { 
  PENDING
  PROCESSING
  SUCCESS
  PARTIAL_FAILURE
  FAILED 
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Organization {
  id           String        @id @default(uuid())
  name         String
  slug         String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  members      Membership[]
  employees    Employee[]
  integrations Integration[]
  invitations  Invitation[]
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  passwordHash  String?        // null for Google-only users
  fullName      String
  avatarUrl     String?
  googleId      String?        @unique
  isVerified    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]
}

model Membership {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  role           UserRole     @default(MEMBER)
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model Invitation {
  id             String       @id @default(uuid())
  email          String
  organizationId String
  role           UserRole     @default(MEMBER)
  invitedById    String
  status         InviteStatus @default(PENDING)
  token          String       @unique @default(uuid())
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Employee {
  id             String         @id @default(uuid())
  organizationId String
  fullName       String
  personalEmail  String
  companyEmail   String?
  department     String
  status         EmployeeStatus @default(ONBOARDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobLogs        JobLog[]
  integrationLogs IntegrationLog[]
}

model Integration {
  id             String       @id @default(uuid())
  organizationId String
  provider       String       // e.g., "GITHUB", "SLACK"
  encryptedKey   String
  iv             String
  authTag        String
  metadata       Json?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  mappings       IntegrationMapping[]

  @@unique([organizationId, provider])
}

model IntegrationMapping {
  id             String      @id @default(uuid())
  integrationId  String
  department     String      // "Engineering", "Marketing"
  resourceId     String      // Slack channel ID "C1234567890"
  resourceName   String      // "#engineering"
  resourceType   String      // "channel", "team", "project"
  createdAt      DateTime    @default(now())

  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, department, resourceId])
}

model JobLog {
  id         String     @id @default(uuid())
  employeeId String
  action     String
  status     JobStatus  @default(PENDING)
  message    String?
  createdAt  DateTime   @default(now())

  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model IntegrationLog {
  id           String    @id @default(uuid())
  employeeId   String
  provider     String
  action       String    // "ONBOARD", "OFFBOARD"
  status       JobStatus @default(PENDING)
  message      String?
  retryCount   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  employee     Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}
